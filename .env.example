NODE_ENV=development
LOGGING_DEBUG=true
DEBUG_REQUESTS=true
AI_DEBUG_LOGS=true
LOG_LEVEL=info

# auth secret token
JWT_SECRET=your_long_secret_key_pai

#AI Model API
AI_PLATFORM=Openrouter
AI_API_KEY=
AI_API_URL=https://openrouter.ai/api/v1/chat/completions
AI_DEFAULT_MODEL=qwen/qwen3.5-flash-02-23
AI_ALTERNARIVE_MODEL=qwen/qwen3-vl-235b-a22b-instruct
AI_EMBEDDING_MODEL=qwen/qwen3-embedding-8b

IMAGE_DEFAULT_PROVIDER=together
TOGETHER_API_KEY=
TOGETHER_API_URL=https://api.together.xyz/v1/images/generations
TOGETHER_IMAGE_MODEL=black-forest-labs/FLUX.2-dev 
#TOGETHER_IMAGE_MODEL=ByteDance-Seed/Seedream-3.0 ## no needs steps

IMAGE_GENERATION_STEPS = 26

XAI_API_KEY=
XAI_API_URL=https://api.x.ai/v1/images/generations
XAI_IMAGE_MODEL=grok-imagine-image

TELEGRAM_BOT_TOKEN=
# Comma-separated list of allowed Telegram user IDs (e.g. 1234567,8901234). If empty, anyone can access.
ALLOWED_TELEGRAM_USER_IDS=