<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>PAIA - System Settings</title>
    <!-- Use absolute paths starting with slash since static path prefix is '/' -->
    <link href="/css/cybercore.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/chat.css">
</head>

<body class="cyber-theme" style="overflow: auto;">
    <div class="container">
        <!-- Main Settings Area -->
        <div style="align-items: center; max-width: 75%; margin: 0 auto;">

            <div class="logo-panel">
                <div class="logo cyber-glitch" data-text="PAIAgent">
                    Open Personal AI Agent
                </div>
                <div class="cyber-status">
                    <div class="cyber-status__dot"></div>
                </div>
            </div>

            <div style="display: flex; gap: 15px; margin-bottom: 20px; width: 550px; max-width: 100%;">
                <a href="/" style="text-decoration: none; flex: 1;">
                    <button class="cyber-btn cyber-btn--cyan" style="width: 100%;">< BACK TO CHAT</button>
                </a>
                <a href="/tasks" style="text-decoration: none; flex: 1;">
                    <button class="cyber-btn cyber-btn--green" style="width: 100%;">TASKS 📋</button>
                </a>
            </div>

            <!-- Setup Warning Banner (inline warning if keys are missing) -->
            <div id="setupWarningBanner"
                style="display: none; background: rgba(255, 0, 85, 0.4); border: 1px solid var(--cyber-secondary); padding: 10px; font-family: var(--font-mono); font-size: 14px; color: var(--cyber-secondary); text-align: center; text-shadow: 0 0 5px var(--cyber-secondary); animation: flicker 0.15s infinite; margin-bottom: 4px; width: 550px; max-width: 100%; border-radius: 4px;">
                ⚠️ FIRST LAUNCH SETUP: AI API Key (OpenRouter) is missing. Please configure it below to enable chat
                functions.
            </div>

            <div class="settings-form-container cyber-tile"
                style="background: rgba(6, 8, 16, 0.95); border: 2px solid var(--cyber-primary); padding: 10px 20px; width: 550px; max-width: 100%; box-shadow: 0 0 25px rgba(0, 255, 136, 0.15); display: flex; flex-direction: column; gap: 20px; border-radius: 4px; box-sizing: border-box;">
                <div class="sessions-title cyber-text-glow"
                    style="font-size: 18px; border-bottom: 1px solid rgba(0, 255, 136, 0.3); padding-bottom: 8px; margin-bottom: 10px;">
                    AGENT CONFIGURATION
                </div>

                <div class="form-group">
                    <label
                        style="display: block; font-family: var(--font-mono); color: var(--cyber-secondary); margin-bottom: 8px; letter-spacing: 1px; text-transform: uppercase;">AI
                        API URL</label>
                    <input type="text" id="settingsAiApiUrl" class="cyber-input"
                        style="width: 100%;font-family: var(--font-mono); padding: 8px;"
                        placeholder="https://openrouter.ai/api/v1/chat/completions">
                    <small
                        style="display: block; font-family: var(--font-mono); font-size: 12px; color: rgba(255,255,255,0.6); margin-top: 5px;">Configure
                        the LLM completions URL. Leave default or change for OpenAI, LM Studio, Ollama, etc.</small>
                </div>

                <div class="form-group">
                    <label
                        style="display: block; font-family: var(--font-mono); color: var(--cyber-secondary); margin-bottom: 8px; letter-spacing: 1px; text-transform: uppercase;">AI
                        Model</label>
                    <input type="text" id="settingsAiDefaultModel" class="cyber-input"
                        style="width: 100%;font-family: var(--font-mono); padding: 8px;"
                        placeholder="qwen/qwen3.5-flash-02-23">
                    <small
                        style="display: block; font-family: var(--font-mono); color: rgba(255,255,255,0.6); margin-top: 5px;">Configure
                        the default model identifier (e.g. qwen/qwen3.5-flash-02-23, or llama3 for Ollama).</small>
                </div>

                <div class="form-group">
                    <label
                        style="display: block; font-family: var(--font-mono); color: var(--cyber-secondary); margin-bottom: 8px; letter-spacing: 1px; text-transform: uppercase;">AI
                        API Key (OpenRouter)</label>
                    <input type="password" id="settingsAiApiKey" class="cyber-input"
                        style="width: 100%;font-family: var(--font-mono); padding: 8px;" placeholder="Not configured">
                    <small
                        style="display: block; font-family: var(--font-mono); color: rgba(255,255,255,0.6); margin-top: 5px;">Required.
                        Used for LLM chat. Enter new key to update, leave empty to keep current, or enter '-' to
                        clear.</small>
                </div>

                <div class="form-group">
                    <label
                        style="display: block; font-family: var(--font-mono); color: var(--cyber-secondary); margin-bottom: 8px; letter-spacing: 1px; text-transform: uppercase;">Together
                        AI API Key</label>
                    <input type="password" id="settingsTogetherApiKey" class="cyber-input"
                        style="width: 100%;font-family: var(--font-mono); padding: 8px;" placeholder="Not configured">
                    <small
                        style="display: block; font-family: var(--font-mono); color: rgba(255,255,255,0.6); margin-top: 5px;">Optional.
                        For image generation features. Enter '-' to clear.</small>
                </div>

                <div class="form-group">
                    <label
                        style="display: block; font-family: var(--font-mono); color: var(--cyber-secondary); margin-bottom: 8px; letter-spacing: 1px; text-transform: uppercase;">X.AI
                        API Key</label>
                    <input type="password" id="settingsXaiApiKey" class="cyber-input"
                        style="width: 100%;font-family: var(--font-mono); padding: 8px;" placeholder="Not configured">
                    <small
                        style="display: block; font-family: var(--font-mono); color: rgba(255,255,255,0.6); margin-top: 5px;">Optional.
                        For Grok image generation. Enter '-' to clear.</small>
                </div>

                <div class="form-group">
                    <label
                        style="display: block; font-family: var(--font-mono); color: var(--cyber-secondary); margin-bottom: 8px; letter-spacing: 1px; text-transform: uppercase;">Telegram
                        Telegram Bot Token</label>
                    <input type="password" id="settingsTelegramToken" class="cyber-input"
                        style="width: 100%;font-family: var(--font-mono); padding: 8px;" placeholder="Not configured">
                    <small
                        style="display: block; font-family: var(--font-mono); color: rgba(255,255,255,0.6); margin-top: 5px;">Optional.
                        For telegram bot interactions. Enter '-' to clear.</small>
                </div>

                <div class="form-group">
                    <label
                        style="display: block; font-family: var(--font-mono); color: var(--cyber-secondary); margin-bottom: 8px; letter-spacing: 1px; text-transform: uppercase;">Allowed Telegram User IDs</label>
                    <input type="text" id="settingsAllowedTelegramUserIds" class="cyber-input"
                        style="width: 100%;font-family: var(--font-mono); padding: 8px;" placeholder="e.g. 1234567,8901234">
                    <small
                        style="display: block; font-family: var(--font-mono); color: rgba(255,255,255,0.6); margin-top: 5px;">Optional.
                        Comma-separated list of Telegram User IDs. Leave empty to allow anyone.</small>
                </div>

                <div class="form-group">
                    <label
                        style="display: block; font-family: var(--font-mono); color: var(--cyber-secondary); margin-bottom: 8px; letter-spacing: 1px; text-transform: uppercase;">Basic Auth Username</label>
                    <input type="text" id="settingsAppUser" class="cyber-input"
                        style="width: 100%;font-family: var(--font-mono); padding: 8px;" placeholder="admin">
                    <small
                        style="display: block; font-family: var(--font-mono); color: rgba(255,255,255,0.6); margin-top: 5px;">Username for Web UI protection. Default is 'admin'.</small>
                </div>

                <div class="form-group">
                    <label
                        style="display: block; font-family: var(--font-mono); color: var(--cyber-secondary); margin-bottom: 8px; letter-spacing: 1px; text-transform: uppercase;">Basic Auth Password</label>
                    <input type="password" id="settingsAppPassword" class="cyber-input"
                        style="width: 100%;font-family: var(--font-mono); padding: 8px;" placeholder="Not configured">
                    <small
                        style="display: block; font-family: var(--font-mono); color: rgba(255,255,255,0.6); margin-top: 5px;">Optional. Leave empty to disable authentication. Enter new password to update, or '-' to clear.</small>
                </div>

                <div class="form-group">
                    <button id="btnSaveSettings" class="cyber-btn">
                        SAVE CONFIG
                    </button>
                </div>
            </div>


        </div>
    </div>

    <script src="/js/settings.js"></script>
</body>

</html>