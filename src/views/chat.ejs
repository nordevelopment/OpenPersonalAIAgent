<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>PAIA - Personal AI Agent Assistant</title>

    <!-- Cybercore CSS -->
    <link href="css/cybercore.css" rel="stylesheet">
    <link rel="stylesheet" href="css/chat.css">
    <link rel="stylesheet" href="css/robotpet.css">
</head>

<body class="cyber-theme">

    <div class="container">
        <!-- Sidebar -->
        <div class="sidebar cyber-bg-primary">
            <div class="logo-panel">
                <div class="logo cyber-nav__brand" data-text="Open PAIAgent">
                    Open PAIAgent
                </div>
                <div class="cyber-status">
                    <div class="cyber-status__dot cyber-icon--pulse"></div>
                </div>
            </div>

            <button id="btnNewChat" class="cyber-btn">
                NEW CHAT
            </button>


            <div class="sidebar-panel">
                <div class="sessions-title cyber-text-glow">SESSIONS</div>
                <div class="sessions-list" id="sessionsList">
                    <!-- Sessions will be loaded here -->
                </div>
            </div>

            <div class="sidebar-panel">
                <div class="sessions-title cyber-text-glow">AGENTS</div>
                <select id="agentSelector" class="cyber-select">
                    <!-- Agents will be loaded here -->
                </select>
                <button id="btnEditAgent" class="cyber-btn">
                    EDIT AGENT
                </button>
                <div class="agent-buttons" style="display: flex; gap: 10px; margin-top: 10px;">
                    <button id="btnCreateAgent" class="cyber-btn cyber-btn--green"
                        style="flex: 1; font-size: 11px; padding: 8px;">
                        CREATE AGENT
                    </button>
                    <button id="btnDeleteAgent" class="cyber-btn cyber-btn--magenta"
                        style="flex: 1; font-size: 11px; padding: 8px;">
                        DELETE AGENT
                    </button>
                </div>
            </div>

            <div class="sidebar-footer">
                <a href="/settings" id="btnOpenSettings" class="cyber-btn --cyan" style="width: 100%;">
                    ⚙️ SETTINGS
                </a>

                <button id="btnClearChat" class="cyber-btn cyber-btn--magenta">
                    CLEAR CHAT
                </button>

                <button id="btnClearMemory" class="cyber-btn cyber-btn--magenta" style="margin-top: 10px; width: 100%;">
                    PURGE MEMORY
                </button>
                <!-- Robot Pet Widget -->
                <div class="sidebar-panel"
                    style="display: flex; justify-content: center; align-items: center; padding: 10px 0; margin-bottom: 5px;">
                    <%- include('robotpet.ejs') %>
                </div>

            </div>
        </div>

        <!-- Chat Area -->
        <div class="chat-area">
            <div class="chat-header cyber-tile--bottom">
                <div class="system-status" id="system-status">SYSTEM INITIALIZING...</div>

                <a href="/tasks" id="btnOpenTasks" class="cyber-btn cyber-btn--green">
                    📋 TASK MANAGER
                </a>
            </div>

            <!-- Setup Warning Banner -->
            <div id="setupWarningBanner"
                style="display: none; background: rgba(255, 0, 85, 0.15); border-bottom: 1px solid var(--cyber-secondary); padding: 12px 20px; font-family: var(--font-mono); font-size: 13px; color: var(--cyber-secondary); text-align: center; text-shadow: 0 0 5px var(--cyber-secondary); animation: flicker 0.15s infinite;">
                ⚠️ SYSTEM OFFLINE: AI API Key is not configured. Please open <a href="#" id="setupWarningLink"
                    style="color: var(--cyber-primary); text-decoration: underline;">Settings</a> to configure your API
                keys.
            </div>

            <div class="chat-messages" id="chatMessages">
                <!-- Messages will load here -->
            </div>

            <div class="typing-indicator" id="typingIndicator">
                <div class="typing-dots">
                    <div class="typing-dot"></div>
                    <div class="typing-dot"></div>
                    <div class="typing-dot"></div>
                </div>
                <span class="typing-text">AI IS THINKING...</span>
            </div>

            <div class="input-area cyber-tile--top">
                <div class="input-container">
                    <div id="imagePreviewContainer" class="image-preview-container">
                        <img id="imagePreview" src="" alt="Selected Preview" />
                        <button id="btnRemoveImage" class="btn-remove" type="button" title="REMOVE IMAGE">×</button>
                    </div>
                    <textarea id="messageInput" class="cyber-textarea"
                        placeholder="Enter the message or task"></textarea>
                </div>
                <div class="send-button-container">

                    <label for="input-image-file" class="icon-card__icon cyber-icon cyber-icon--cyan"
                        style="width: 30px; height: 30px; cursor: pointer;">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="32"
                            height="32">
                            <rect x="3" y="3" width="18" height="18" rx="2" />
                            <circle cx="8.5" cy="8.5" r="1.5" fill="#000" />
                            <path fill="#000" d="M21 15l-5-5L5 21" />
                        </svg>
                        <!-- Or use the raw SVG files from node_modules/cybercore-css/src/icons/svg/ -->
                    </label>
                    <input type="file" id="input-image-file" accept="image/*" style="display:none;">

                    <button id="sendButton" class="cyber-btn" style="background-color: aqua;">
                        <svg class="send-icon" viewBox="0 0 24 24" width="24" height="24">
                            <path d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z" />
                        </svg>
                    </button>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
    <script src="js/robotpet.js"></script>
    <script src="js/chat.js"></script>
</body>

</html>